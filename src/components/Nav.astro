---
import KeycapLogo from './KeycapLogo.astro';

const links = [
  { href: '/#aanpak', label: 'Aanpak' },
  { href: '/over-ons', label: 'Over ons' },
  { href: '/pilot', label: 'Eerste 3 klanten' },
];
---

<header class="sticky top-0 z-50 border-b border-charcoal/10 bg-paper/90 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4" aria-label="Hoofdnavigatie">
    <a href="/" class="flex items-center gap-3">
      <KeycapLogo class="h-7 w-auto" />
      <span class="font-heading text-lg font-semibold tracking-tight text-ink">QWER</span>
    </a>

    <div class="hidden items-center gap-8 lg:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="font-body text-sm text-ink transition-colors hover:text-teal"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/#contact"
        class="keycap-shadow rounded-lg bg-teal px-5 py-2.5 font-body text-sm font-medium text-white transition-colors hover:bg-teal-dark"
      >
        Plan een kennismaking
      </a>
    </div>

    <button
      id="nav-toggle"
      type="button"
      class="flex flex-col gap-1.5 p-2 lg:hidden"
      aria-label="Menu openen"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <span class="block h-0.5 w-6 bg-ink"></span>
      <span class="block h-0.5 w-6 bg-ink"></span>
      <span class="block h-0.5 w-6 bg-ink"></span>
    </button>
  </nav>

  <div
    id="nav-menu"
    data-open="false"
    class="grid grid-rows-[0fr] border-t border-charcoal/10 bg-paper transition-[grid-template-rows] duration-300 ease-out data-[open=true]:grid-rows-[1fr] lg:hidden"
  >
    <div class="flex flex-col gap-1 overflow-hidden px-6">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="border-b border-charcoal/5 py-4 font-body text-base text-ink"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/#contact"
        class="keycap-shadow my-4 rounded-lg bg-teal px-5 py-3 text-center font-body text-sm font-medium text-white"
      >
        Plan een kennismaking
      </a>
    </div>
  </div>
</header>
