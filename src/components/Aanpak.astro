---
const steps = [
  {
    number: '01',
    title: 'Kennismaking',
    body: 'Een gratis gesprek van een uur. Jij vertelt hoe je werk eruitziet, wij stellen vragen. Aan het eind weet je waar de grootste kansen liggen, ook als je daarna niet met ons verdergaat.',
  },
  {
    number: '02',
    title: 'Trainingsdag op maat',
    body: 'Een volledige dag met je team, op locatie. We pakken echte processen uit jouw bedrijf en laten zien wat AI daar wel en niet kan. Iedereen gaat zelf aan de slag, niemand kijkt alleen toe.',
  },
  {
    number: '03',
    title: 'Aan de slag',
    body: 'Je team gaat naar huis met toepassingen die morgen bruikbaar zijn, plus een helder antwoord op de vraag: wat is voor ons de logische volgende stap, en wat kunnen we gerust laten liggen?',
  },
];
---

<section id="aanpak" class="bg-charcoal px-6 py-20 text-cream md:py-28">
  <div class="mx-auto max-w-4xl">
    <div class="reveal mx-auto max-w-[65ch] text-center">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-mint">De aanpak</p>
      <h2 class="mt-4 font-heading text-3xl font-semibold leading-tight text-cream sm:text-4xl">
        In drie stappen van vraag naar resultaat.
      </h2>
    </div>

    <ol class="mt-14 space-y-10 md:space-y-14">
      {
        steps.map((step, i) => (
          <li
            class="reveal flex flex-col gap-2 border-b border-cream/10 pb-10 last:border-none last:pb-0 md:flex-row md:items-baseline md:gap-8"
            style={`transition-delay: ${i * 100}ms`}
          >
            <span class="font-mono text-2xl font-semibold text-mint md:w-16 md:shrink-0">
              {step.number}
            </span>
            <div>
              <h3 class="font-heading text-xl font-semibold text-cream">{step.title}</h3>
              <p class="mt-2 max-w-[60ch] font-body text-base text-cream/75">{step.body}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
