---
import KeycapLogo from './KeycapLogo.astro';
---

<section id="hero" class="bg-paper px-6 pb-20 pt-16 md:pb-28 md:pt-24">
  <div class="mx-auto flex max-w-4xl flex-col items-center gap-10 text-center">
    <p class="font-mono text-xs uppercase tracking-[0.25em] text-gray">
      AI-training voor het mkb
    </p>

    <h1 class="font-heading text-4xl font-semibold leading-[1.1] tracking-tight text-ink sm:text-5xl md:text-6xl">
      Je weet dat AI belangrijk is.<br />
      <span class="text-teal">De rest volgt.</span>
    </h1>

    <p class="max-w-[38ch] text-balance font-body text-base text-gray sm:text-lg">
      QWER helpt Nederlandse mkb-bedrijven van AI-onzekerheid naar concrete actie. Praktische
      trainingen op maat: geen tools, geen jargon, wel een plan.
    </p>

    <div class="flex flex-col items-center gap-4 sm:flex-row">
      <a
        href="#contact"
        class="keycap-shadow rounded-lg bg-teal px-7 py-3.5 font-body text-sm font-medium text-white transition-colors hover:bg-teal-dark"
      >
        Plan een kennismaking
      </a>
      <a
        href="#aanpak"
        class="rounded-lg border border-charcoal/20 px-7 py-3.5 font-body text-sm font-medium text-ink transition-colors hover:border-charcoal/40"
      >
        Zo werkt het
      </a>
    </div>

    <KeycapLogo class="mt-6 h-16 w-auto sm:h-20 md:h-24" animated />
  </div>
</section>
