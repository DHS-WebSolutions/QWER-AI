---
const cards = [
  {
    title: 'Eén trainingsdag, jouw bedrijf centraal',
    body: 'Een volledige dag met jouw team, op locatie. Geen algemene AI-cursus, maar een programma dat wij vooraf bouwen rond jullie eigen processen: de offertes, de mailbox, de planning, de rapportages. Wat er op tafel ligt, komt uit jullie eigen werk.',
  },
  {
    title: 'Naar huis met een plan',
    body: 'Aan het eind van de dag heeft je team toepassingen die morgen bruikbaar zijn, en jij een helder beeld: waar zit voor ons de winst, wie pakt wat op, en wat laten we bewust liggen. Geen rapport voor in de la, maar afspraken waar je op kunt sturen.',
  },
  {
    title: 'Begeleiding, geen verkooppraatje',
    body: 'Wij verkopen geen software en geen abonnement. We verdienen niets aan de tools die we bespreken, dus we kunnen eerlijk zijn over wat werkt en wat hype is. Na de training sta je op eigen benen.',
  },
];
---

<section id="wat-we-doen" class="bg-paper px-6 py-20 md:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mx-auto max-w-[65ch] text-center">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-gray">Wat we doen</p>
      <h2 class="mt-4 font-heading text-3xl font-semibold leading-tight text-ink sm:text-4xl">
        Geen software. Wel inzicht.
      </h2>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {
        cards.map((card, i) => (
          <div
            class="reveal keycap-card rounded-2xl bg-cream p-8"
            style={`transition-delay: ${i * 100}ms`}
          >
            <h3 class="font-heading text-xl font-semibold text-ink">{card.title}</h3>
            <p class="mt-3 font-body text-base text-gray">{card.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
