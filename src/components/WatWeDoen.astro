---
const cards = [
  {
    title: 'Workshops op maat',
    body: 'Hands-on sessies waarin je team ontdekt waar AI echt tijd en geld bespaart. Toegespitst op jouw sector en jouw processen.',
  },
  {
    title: 'Pilot om te starten',
    body: 'We beginnen klein en concreet. Eén afdeling, één proces. Werkt het? Dan bouwen we verder. Zo niet? Dan weet je dat — zonder groot risico.',
  },
  {
    title: 'Begeleiding, geen verkooppraatje',
    body: 'Wij verkopen geen abonnement en geen platform. We helpen je zélf de juiste keuzes maken. Daarna sta je op eigen benen.',
  },
];
---

<section id="wat-we-doen" class="bg-paper px-6 py-20 md:py-28">
  <div class="mx-auto max-w-6xl">
    <div class="reveal mx-auto max-w-[65ch] text-center">
      <p class="font-mono text-xs uppercase tracking-[0.25em] text-gray">Wat we doen</p>
      <h2 class="mt-4 font-heading text-3xl font-semibold leading-tight text-ink sm:text-4xl">
        Geen software. Wel inzicht.
      </h2>
    </div>

    <div class="mt-14 grid gap-8 md:grid-cols-3">
      {
        cards.map((card, i) => (
          <div
            class="reveal keycap-card rounded-2xl bg-cream p-8"
            style={`transition-delay: ${i * 100}ms`}
          >
            <h3 class="font-heading text-xl font-semibold text-ink">{card.title}</h3>
            <p class="mt-3 font-body text-base text-gray">{card.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
