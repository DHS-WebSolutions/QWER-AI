---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = 'Word een van onze eerste drie klanten · QWER';
const description =
  'QWER geeft de eerste drie trainingsdagen weg zonder factuur, in ruil voor eerlijke feedback en een referentie. Drie plekken, vanaf september.';

const deal = [
  {
    title: 'Jij krijgt',
    body: 'Een volledige trainingsdag op maat, op locatie, voor je hele team. Inclusief voorbereiding rond jullie eigen processen en het plan waarmee je naar huis gaat. Onze volledige trainingsdag, zonder factuur.',
  },
  {
    title: 'Wij vragen',
    body: 'Een uur voorbereiding met ons vooraf. Eerlijke feedback achteraf, ook als die kritisch is. En als je tevreden bent: een quote en de bereidheid om als referentie te dienen voor toekomstige klanten.',
  },
];

const schedule = [
  {
    time: '09:00',
    title: 'Waar staan jullie nu?',
    body: 'We beginnen bij jullie processen, niet bij AI.',
  },
  {
    time: '10:30',
    title: 'Hands-on',
    body: 'Iedereen aan de slag met een echte taak uit het eigen werk.',
  },
  {
    time: '13:00',
    title: 'Verdieping',
    body: 'Wat kan er nog meer, en wat laten we bewust liggen?',
  },
  {
    time: '15:30',
    title: 'Het plan',
    body: 'Wie pakt wat op, en wat is de eerstvolgende stap?',
  },
];

const faqs = [
  {
    q: 'Zit er een addertje onder het gras?',
    a: 'Nee. Geen verplichting tot vervolg, geen abonnement, geen verkooppraatje op de dag zelf.',
  },
  {
    q: 'Waarom doen jullie dit?',
    a: 'We zijn net begonnen. In deze fase is bewijs ons meer waard dan omzet. Jullie ervaring wordt de basis waarmee we volgende klanten overtuigen.',
  },
  {
    q: 'Wat als de training ons niks oplevert?',
    a: 'Dan horen we dat graag. Dat is letterlijk de deal: eerlijke feedback, ook als die kritisch is.',
  },
  {
    q: 'Wanneer vinden de trainingen plaats?',
    a: 'Vanaf september, in overleg. De voorbereiding plannen we een paar weken vooraf.',
  },
];
---

<Layout title={title} description={description}>
  <Nav />
  <main>
    <section class="bg-paper px-6 pb-20 pt-16 md:pb-28 md:pt-24">
      <div class="mx-auto flex max-w-4xl flex-col items-center gap-10 text-center">
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-gray">Founding clients</p>

        <h1 class="font-heading text-4xl font-semibold leading-[1.1] tracking-tight text-ink sm:text-5xl md:text-6xl">
          We zoeken drie bedrijven om mee te beginnen.
        </h1>

        <p class="max-w-[52ch] text-balance font-body text-base text-gray sm:text-lg">
          QWER is nieuw. Onze aanpak staat, maar we willen hem scherpstellen in de praktijk voordat
          we hem breed aanbieden. Daarom geven we de eerste drie trainingsdagen weg zonder
          factuur. Niet omdat ze niks waard zijn, maar omdat jullie feedback ons meer waard is.
        </p>

        <a
          href="#aanmelden"
          class="keycap-shadow rounded-lg bg-teal px-7 py-3.5 font-body text-sm font-medium text-white transition-colors hover:bg-teal-dark"
        >
          Meld je bedrijf aan
        </a>
      </div>
    </section>

    <section class="bg-charcoal px-6 py-20 text-cream md:py-28">
      <div class="mx-auto max-w-5xl">
        <div class="reveal mx-auto max-w-[65ch] text-center">
          <p class="font-mono text-xs uppercase tracking-[0.25em] text-mint">De deal</p>
        </div>

        <div class="mt-10 grid gap-8 sm:grid-cols-2">
          {
            deal.map((item, i) => (
              <div class="reveal keycap-card rounded-2xl bg-cream p-8" style={`transition-delay: ${i * 100}ms`}>
                <h3 class="font-heading text-xl font-semibold text-ink">{item.title}</h3>
                <p class="mt-3 font-body text-base text-gray">{item.body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-paper px-6 py-20 md:py-28">
      <div class="reveal mx-auto max-w-[65ch] text-center">
        <p class="font-mono text-xs uppercase tracking-[0.25em] text-gray">Voor wie</p>
        <h2 class="mt-4 font-heading text-3xl font-semibold leading-tight text-ink sm:text-4xl">
          Dit werkt alleen als het bij je past.
        </h2>
        <p class="mx-auto mt-6 max-w-[60ch] font-body text-base text-gray sm:text-lg">
          We zoeken bedrijven die aan drie dingen voldoen: je hebt 5 tot 100 mensen in dienst, de
          beslisser is zelf bij de training aanwezig, en je bent bereid om na afloop echt te
          zeggen wat je ervan vond. Drie plekken, vanaf september. Vergeven is vergeven.
        </p>
      </div>
    </section>

    <section class="bg-charcoal px-6 py-20 text-cream md:py-28">
      <div class="mx-auto max-w-4xl">
        <div class="reveal mx-auto max-w-[65ch] text-center">
          <p class="font-mono text-xs uppercase tracking-[0.25em] text-mint">Het programma</p>
          <h2 class="mt-4 font-heading text-3xl font-semibold leading-tight text-cream sm:text-4xl">
            Zo ziet de dag eruit.
          </h2>
        </div>

        <ol class="mt-14 space-y-10 md:space-y-14">
          {
            schedule.map((step, i) => (
              <li
                class="reveal flex flex-col gap-2 border-b border-cream/10 pb-10 last:border-none last:pb-0 md:flex-row md:items-baseline md:gap-8"
                style={`transition-delay: ${i * 100}ms`}
              >
                <span class="font-mono text-2xl font-semibold text-mint md:w-24 md:shrink-0">
                  {step.time}
                </span>
                <div>
                  <h3 class="font-heading text-xl font-semibold text-cream">{step.title}</h3>
                  <p class="mt-2 max-w-[60ch] font-body text-base text-cream/75">{step.body}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
    </section>

    <section class="bg-paper px-6 py-20 md:py-28">
      <div class="mx-auto max-w-4xl">
        <div class="reveal mx-auto max-w-[65ch] text-center">
          <p class="font-mono text-xs uppercase tracking-[0.25em] text-gray">Veelgestelde vragen</p>
        </div>

        <div class="mt-14 space-y-8 md:space-y-10">
          {
            faqs.map((item, i) => (
              <div class="reveal border-b border-charcoal/10 pb-8 last:border-none last:pb-0" style={`transition-delay: ${i * 100}ms`}>
                <h3 class="font-heading text-lg font-semibold text-ink">{item.q}</h3>
                <p class="mt-2 font-body text-base text-gray">{item.a}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="aanmelden" class="bg-charcoal px-6 py-20 text-cream md:py-28">
      <div class="mx-auto max-w-2xl">
        <div class="reveal flex flex-col items-center text-center">
          <p class="font-mono text-xs uppercase tracking-[0.25em] text-mint">Founding clients</p>
          <h2 class="mt-4 font-heading text-3xl font-semibold leading-tight text-cream sm:text-4xl">
            Meld je bedrijf aan
          </h2>
          <p class="mx-auto mt-6 max-w-[55ch] font-body text-base text-cream/75 sm:text-lg">
            Vul dit in en we nemen binnen twee werkdagen contact op voor een kort
            kennismakingsgesprek. Daarin beslissen we samen of het past.
          </p>
        </div>

        <form
          name="pilot-aanmelding"
          method="POST"
          action="/bedankt"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="reveal mt-12 space-y-5"
        >
          <input type="hidden" name="form-name" value="pilot-aanmelding" />
          <p hidden>
            <label>
              Niet invullen: <input name="bot-field" />
            </label>
          </p>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="naam" class="mb-1.5 block font-mono text-xs uppercase tracking-widest text-cream/60">
                Naam
              </label>
              <input
                type="text"
                id="naam"
                name="name"
                required
                class="w-full rounded-lg border border-cream/20 bg-cream/5 px-4 py-3 font-body text-cream placeholder:text-cream/30 focus:border-teal focus:outline-none focus:ring-2 focus:ring-teal/40"
              />
            </div>
            <div>
              <label for="bedrijf" class="mb-1.5 block font-mono text-xs uppercase tracking-widest text-cream/60">
                Bedrijf
              </label>
              <input
                type="text"
                id="bedrijf"
                name="company"
                required
                class="w-full rounded-lg border border-cream/20 bg-cream/5 px-4 py-3 font-body text-cream placeholder:text-cream/30 focus:border-teal focus:outline-none focus:ring-2 focus:ring-teal/40"
              />
            </div>
          </div>

          <div>
            <label for="email" class="mb-1.5 block font-mono text-xs uppercase tracking-widest text-cream/60">
              E-mail
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full rounded-lg border border-cream/20 bg-cream/5 px-4 py-3 font-body text-cream placeholder:text-cream/30 focus:border-teal focus:outline-none focus:ring-2 focus:ring-teal/40"
            />
          </div>

          <div>
            <label for="medewerkers" class="mb-1.5 block font-mono text-xs uppercase tracking-widest text-cream/60">
              Aantal medewerkers
            </label>
            <select
              id="medewerkers"
              name="team_size"
              required
              class="w-full rounded-lg border border-cream/20 bg-cream/5 px-4 py-3 font-body text-cream focus:border-teal focus:outline-none focus:ring-2 focus:ring-teal/40"
            >
              <option value="" selected disabled>Kies een optie</option>
              <option value="1 tot 5">1 tot 5</option>
              <option value="5 tot 20">5 tot 20</option>
              <option value="20 tot 50">20 tot 50</option>
              <option value="50 tot 100">50 tot 100</option>
              <option value="Meer dan 100">Meer dan 100</option>
            </select>
          </div>

          <div>
            <label for="taak" class="mb-1.5 block font-mono text-xs uppercase tracking-widest text-cream/60">
              Waar verliest je team nu de meeste tijd aan?
            </label>
            <textarea
              id="taak"
              name="time_sink"
              rows="4"
              required
              class="w-full rounded-lg border border-cream/20 bg-cream/5 px-4 py-3 font-body text-cream placeholder:text-cream/30 focus:border-teal focus:outline-none focus:ring-2 focus:ring-teal/40"
            ></textarea>
          </div>

          <button
            type="submit"
            class="keycap-shadow w-full rounded-lg bg-teal px-7 py-3.5 font-body text-sm font-medium text-white transition-colors hover:bg-teal-dark sm:w-auto"
          >
            Verstuur aanmelding
          </button>
        </form>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
