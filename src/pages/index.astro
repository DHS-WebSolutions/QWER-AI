---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Probleem from '../components/Probleem.astro';
import WatWeDoen from '../components/WatWeDoen.astro';
import Aanpak from '../components/Aanpak.astro';
import WaaromQwer from '../components/WaaromQwer.astro';
import VoorWie from '../components/VoorWie.astro';
import OverOns from '../components/OverOns.astro';
import PilotTeaser from '../components/PilotTeaser.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

const title = 'QWER · AI-training voor het mkb. De rest volgt.';
const description =
  'QWER helpt Nederlandse mkb-bedrijven praktisch aan de slag met AI, met trainingsdagen op maat. Geen tools, geen jargon, wel een plan.';
---

<Layout title={title} description={description}>
  <Nav />
  <main>
    <Hero />
    <Probleem />
    <WatWeDoen />
    <Aanpak />
    <WaaromQwer />
    <VoorWie />
    <OverOns />
    <PilotTeaser />
    <Contact />
  </main>
  <Footer />
</Layout>
